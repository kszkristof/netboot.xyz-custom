#!ipxe

# Use a direct mirror to avoid redirect issues
set mirror http://mirrors.leaseweb.com/fedora/releases/41
set arch x86_64
set repo ${mirror}/Everything/${arch}/os

# Troubleshooting: Print the URI to make sure it's correct
echo Loading Fedora 41 from: ${repo}

# Start installer
# We add 'initrd=initrd.img' to the kernel line so the kernel knows to mount it
kernel ${repo}/images/pxeboot/vmlinuz initrd=initrd.img inst.repo=${repo} ip=dhcp
initrd ${repo}/images/pxeboot/initrd.img
boot
